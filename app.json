{
  "expo": {
    "name": "Tennis Pong",
    "slug": "tennis-pong",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/appstore.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brooklynguo.tennispong"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appstore.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.brooklynguo.tennispong"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "tennispong",
    "experiments": {
      "typedRoutes": true
    }
  }
}